  "conflict_rules": [
    {
      "id": "pianissimo_vs_energy",
      "trigger": "sub_pianissimo",
      "locks": ["sub_max_energy","sub_fortissimo","sub_808_kick","sub_anthemic","sub_wall_of_sound"],
      "msg": "Pianissimo tidak bisa digabung dengan Maximum Energy / Fortissimo"
    },
    {
      "id": "final_climax_outro",
      "trigger": "sub_final_climax",
      "warn_sections": ["outro"],
      "msg": "Final Climax sebaiknya di Chorus terakhir, bukan Outro"
    },
    {
      "id": "senggakan_chorus",
      "trigger": "sub_senggakan",
      "warn_sections": ["chorus","drop"],
      "msg": "Senggakan akan tenggelam di Chorus penuh — pindah ke Post-Chorus"
    },
    {
      "id": "modulation_solo",
      "trigger": "sub_modulation",
      "warn_sections": ["solo"],
      "msg": "Modulation di Solo bisa membuat melodi terdengar salah nada"
    },
    {
      "id": "glitch_808",
      "trigger": "sub_glitch_vocal",
      "warn_with": ["sub_808_kick","sub_max_energy"],
      "msg": "Glitch Vocals + Heavy 808 bisa clipping — pastikan ada Sidechain"
    }
  ],
